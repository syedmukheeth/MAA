generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  CUSTOMER
}

model SiteSettings {
  id String @id @default("singleton")

  /// Displayed prices are GST-inclusive (Indian B2C retail norm). This rate is
  /// used to break the tax component OUT of the total for invoicing, not to add
  /// it on top. Stored per-order at purchase time so historical orders keep the
  /// rate they were actually charged.
  gstRate Decimal @default(18) @db.Decimal(5, 2)

  /// Flat delivery fee added to the order. Waived above the threshold.
  deliveryFee           Decimal  @default(0) @db.Decimal(10, 2)
  freeDeliveryThreshold Decimal? @db.Decimal(10, 2)

  heroHeadline    String
  heroSubtext     String
  heroImageUrl    String

  brandLabel      String
  brandHeadline   String

  statYearsExperience   Int
  statProjectsDelivered Int
  statHappyFamilies     Int
  statGoogleRating      String

  showroomAddress  String
  showroomHours    String
  showroomPhone    String
  showroomWhatsapp String

  instagramUrl String?
  facebookUrl  String?

  deliveryMessage String

  updatedAt DateTime @updatedAt
}

enum RoomCategory {
  LIVING_ROOM
  BEDROOM
  DINING
  OFFICE
  OUTDOOR
}

enum RequestStatus {
  NEW
  IN_REVIEW
  QUOTED
  CONVERTED
  CLOSED
}

enum StockMovementType {
  RECEIVED
  SOLD
  RETURNED
  DAMAGED
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products                Product[]                @relation("ProductCreatedBy")
  combos                  Combo[]                   @relation("ComboCreatedBy")
  customFurnitureRequests CustomFurnitureRequest[]  @relation("SubmittedBy")
  testimonials            Testimonial[]             @relation("TestimonialCreatedBy")
  auditLogs               AuditLog[]                @relation("AuditActor")
  cart                    Cart?
  orders                  Order[]

  @@index([role])
}

model Product {
  id                String       @id @default(cuid())
  name              String
  slug              String       @unique
  description       String
  price             Decimal      @db.Decimal(10, 2)
  category          RoomCategory
  materials         String[]
  dimensions        String?
  images            String[]
  stockQuantity     Int          @default(0)
  lowStockThreshold Int          @default(5)
  featured          Boolean      @default(false)
  createdById       String
  createdBy         User         @relation("ProductCreatedBy", fields: [createdById], references: [id])
  comboItems        ComboItem[]
  cartItems         CartItem[]
  variants          Variant[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([category])
  @@index([featured])
}

model Variant {
  id                String          @id @default(cuid())
  productId         String
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name              String
  woodType          String?
  finish            String?
  size              String?
  priceDelta        Decimal         @default(0) @db.Decimal(10, 2)
  sku               String?         @unique
  stock             Int             @default(0)
  lowStockThreshold Int             @default(3)
  isDefault         Boolean         @default(false)
  cartItems         CartItem[]
  orderItems        OrderItem[]
  movements         StockMovement[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([productId, name])
  @@index([productId])
}

model StockMovement {
  id        String            @id @default(cuid())
  variantId String
  variant   Variant           @relation(fields: [variantId], references: [id], onDelete: Cascade)
  type      StockMovementType
  qty       Int
  reason    String?
  orderId   String?
  byUserId  String?
  createdAt DateTime          @default(now())

  @@index([variantId, createdAt])
  @@index([orderId])
}

model Combo {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  bundlePrice Decimal     @db.Decimal(10, 2)
  image       String?
  isActive    Boolean     @default(true)
  items       ComboItem[]
  cartItems   CartItem[]
  createdById String
  createdBy   User        @relation("ComboCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([isActive])
}

model ComboItem {
  id        String  @id @default(cuid())
  comboId   String
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@unique([comboId, productId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])
  comboId   String?
  combo     Combo?   @relation(fields: [comboId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
  @@unique([cartId, comboId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)

  /// Sum of line totals. GST-INCLUSIVE — this is what the customer saw.
  subtotal Decimal @db.Decimal(10, 2)
  /// Delivery charge applied at purchase time.
  deliveryFee Decimal @default(0) @db.Decimal(10, 2)
  /// The GST rate in force when this order was placed. Frozen deliberately:
  /// if the rate changes, past invoices must not silently change with it.
  taxRate Decimal @default(0) @db.Decimal(5, 2)
  /// The GST component contained WITHIN (subtotal + deliveryFee). Not added on.
  taxAmount Decimal @default(0) @db.Decimal(10, 2)
  /// subtotal + deliveryFee. What the customer pays.
  total Decimal @db.Decimal(10, 2)

  paymentMethod   String      @default("COD")
  shippingName    String
  shippingPhone   String
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingState   String
  shippingPincode String
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  comboId     String?
  variantId   String?
  variant     Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantName String?
  name        String
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int
  lineTotal   Decimal  @db.Decimal(10, 2)
}

/// Real customer testimonials, entered by staff.
///
/// This model exists so the storefront never has to fabricate one. The section
/// renders nothing when there are no published rows — an empty trust block is
/// honest; an invented one is a consumer-protection problem (CCPA / BIS
/// IS 19000:2022) and destroys the exact trust it pretends to build.
model Testimonial {
  id          String   @id @default(cuid())
  name        String
  location    String?
  quote       String
  rating      Int      @default(5)
  imageUrl    String?
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdById String?
  createdBy   User?    @relation("TestimonialCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

/// Who changed what. Required by ULTRAPLAN §2 and previously absent entirely —
/// nothing recorded who altered a price, deleted a product, cancelled an order,
/// or granted a role. With three staff tiers touching money and stock, this is
/// the primary internal control.
model AuditLog {
  id       String  @id @default(cuid())
  actorId  String
  actor    User    @relation("AuditActor", fields: [actorId], references: [id])
  /// Dotted action, e.g. "product.delete", "user.role_change".
  action   String
  entity   String
  entityId String?
  /// Human-readable one-liner for the admin table.
  summary  String?
  /// Before/after detail. Never store secrets here.
  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([entity, entityId])
}

model CustomFurnitureRequest {
  id             String        @id @default(cuid())
  name           String
  phone          String
  inspirationUrl String?
  imageUrl       String?
  dimensions     String?
  wood           String?
  finish         String?
  budgetRange    String?
  description    String?
  status         RequestStatus @default(NEW)
  submittedById  String?
  submittedBy    User?         @relation("SubmittedBy", fields: [submittedById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
}
